# Copiá este archivo a .env y completá solo lo que necesite el modo elegido
# en config.yaml. .env está en .gitignore, nunca se versiona.
#
# Modo 100% local (default: llm.provider=ollama, tts.provider=piper; también
# llm.provider=lmstudio) no necesita ninguna de estas variables.

# llm.provider: anthropic
ANTHROPIC_API_KEY=

# llm.provider: openai
OPENAI_API_KEY=

# llm.provider: deepseek
DEEPSEEK_API_KEY=

# llm.provider: lmstudio (opcional -- solo si expusiste el servidor detrás
# de un proxy que exige token; el nombre de variable es el que pongas en
# llm.lmstudio.api_key_env, este es solo un ejemplo)
# LMSTUDIO_API_KEY=

# tts.provider: elevenlabs
ELEVENLABS_API_KEY=

# tts.provider: cartesia
CARTESIA_API_KEY=
