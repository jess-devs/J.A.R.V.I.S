# Rust
/target
# Cargo.lock se versiona a propósito (binario, no librería) para builds reproducibles.

# Python (workers)
workers/.venv/
workers/__pycache__/
**/__pycache__/
*.pyc

# Caché de calibración de hardware del STT (específico de cada máquina)
workers/.cache/

# Voces de Piper descargadas (pesan varias decenas de MB, se descargan aparte)
/voices/*
!/voices/.gitkeep

# Música del modo bienvenida (mp3 del usuario, con copyright, no se versiona)
/assets/music/*
!/assets/music/.gitkeep

# Secretos
.env

# Log que RealtimeSTT escribe en el directorio de trabajo al correr el worker de STT
realtimesst.log

# Memoria persistente del agente (base SQLite local, específica de cada usuario)
/data/

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# IA
.claude
