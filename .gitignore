# Rust
/target
# Cargo.lock se versiona a propósito (binario, no librería) para builds reproducibles.

# Python (workers)
workers/.venv/
workers/__pycache__/
**/__pycache__/
*.pyc

# Voces de Piper descargadas (pesan varias decenas de MB, se descargan aparte)
/voices/*
!/voices/.gitkeep

# Modelo de reconocimiento de voz (Parakeet-TDT + Silero VAD, ~640MB, lo
# descarga scripts/setup.ps1/setup.sh)
/models/stt/*
!/models/stt/.gitkeep

# Música del modo bienvenida (mp3 del usuario, con copyright, no se versiona)
/assets/music/*
!/assets/music/.gitkeep

# Secretos
.env

# Logs de tracing cuando la interfaz Ratatui está activa (ui.enabled: true)
logs/

# Memoria persistente del agente (base SQLite local, específica de cada usuario)
/data/

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# IA
.claude
